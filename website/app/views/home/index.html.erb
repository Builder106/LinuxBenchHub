<section class="brand-hero mb-5">
  <div class="brand-hero-eyebrow">Ruby on Rails &middot; Devise &middot; Chartkick</div>
  <h1 class="display-5 fw-bold">Run your own Linux benchmarks</h1>
  <p class="lead mt-3 mx-auto">
    Submit Phoronix Test Suite results from your own machines, compare them side by side, and
    share the ones worth sharing. Looking for the official CI-captured dataset instead?
    <%= link_to "See the showcase", showcase_path %>.
  </p>
  <div class="mt-4">
    <% if user_signed_in? %>
      <%= link_to 'Start Benchmarking', performance_benchmarks_path, class: 'btn btn-primary btn-lg me-2' %>
    <% else %>
      <%= link_to 'Get Started', new_user_registration_path, class: 'btn btn-primary btn-lg me-2' %>
      <%= link_to 'Explore Benchmarks', performance_benchmarks_path, class: 'btn btn-outline-primary btn-lg' %>
    <% end %>
  </div>
</section>

<section class="mt-5">
  <h2 class="text-center mb-4">Key features</h2>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="brand-feature-card">
        <div class="brand-feature-mark">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M4 20L10 4L14 16L20 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h5>Effortless benchmarking</h5>
        <p>Run comprehensive benchmarks on various Linux distributions with just a few clicks.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="brand-feature-card">
        <div class="brand-feature-mark">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="4" y="12" width="4" height="8" fill="currentColor"/>
            <rect x="10" y="7" width="4" height="13" fill="currentColor"/>
            <rect x="16" y="3" width="4" height="17" fill="currentColor"/>
          </svg>
        </div>
        <h5>Detailed comparisons</h5>
        <p>Compare benchmark results side by side with interactive charts to make informed decisions.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="brand-feature-card">
        <div class="brand-feature-mark">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="6" cy="12" r="2.5" stroke="currentColor" stroke-width="1.8"/>
            <circle cx="18" cy="6" r="2.5" stroke="currentColor" stroke-width="1.8"/>
            <circle cx="18" cy="18" r="2.5" stroke="currentColor" stroke-width="1.8"/>
            <path d="M8.2 10.8L15.8 7.2M8.2 13.2L15.8 16.8" stroke="currentColor" stroke-width="1.8"/>
          </svg>
        </div>
        <h5>Save &amp; share results</h5>
        <p>Save your benchmark configurations and results, then share them with the community.</p>
      </div>
    </div>
  </div>
</section>
