<% size = local_assigns.fetch(:size, 44) %>
<% label = { "ubuntu" => "Ubuntu", "fedora" => "Fedora", "debian" => "Debian" }.fetch(distro) %>
<%
  # Intrinsic viewBox aspect (width / height) of each official logo asset,
  # so the badge frame stays a fixed square without skewing the artwork.
  aspect = { "ubuntu" => 767.40668 / 738.31421, "fedora" => 1.0, "debian" => 87.041 / 108.445 }.fetch(distro)
  img_w, img_h = aspect >= 1 ? [size, size / aspect] : [size * aspect, size]
%>
<span class="distro-mark <%= local_assigns[:css_class] %>" style="display:inline-flex;align-items:center;justify-content:center;width:<%= size %>px;height:<%= size %>px;">
  <%= image_tag "distros/#{distro}.svg", width: img_w.round(2), height: img_h.round(2), alt: label %>
</span>
