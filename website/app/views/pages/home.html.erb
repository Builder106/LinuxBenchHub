<main>
  <img class="banner banner-dark" src="/banner-dark.svg" alt="LinuxBenchHub — compare Linux distros under identical virtual hardware" width="1200" height="420">
  <img class="banner banner-light" src="/banner-light.svg" alt="" aria-hidden="true" width="1200" height="420">

  <div class="badges">
    <a href="https://github.com/Builder106/LinuxBenchHub/actions/workflows/ci.yml" target="_blank" rel="noreferrer">
      <img src="https://github.com/Builder106/LinuxBenchHub/actions/workflows/ci.yml/badge.svg" alt="CI">
    </a>
    <img src="https://img.shields.io/badge/Ruby-3.3.0-CC342D.svg?logo=ruby&logoColor=white" alt="Ruby 3.3">
    <img src="https://img.shields.io/badge/Rails-8.0-D30001.svg?logo=rubyonrails&logoColor=white" alt="Rails 8">
    <img src="https://img.shields.io/badge/license-MIT-blue.svg" alt="MIT">
    <img src="https://img.shields.io/badge/status-in--development-orange.svg" alt="In development">
  </div>

  <p class="lede">
    A benchmarking dataset for Linux distros — Phoronix Test Suite runs
    on Ubuntu, Fedora, and Debian, captured monthly in GitHub Actions on
    identical runner hardware, with a Rails dashboard and R parsers
    consuming the same composite XML.
  </p>

  <div class="callout">
    <strong>Note</strong> this site is the static showcase. Fresh captures
    land in the repo on the 1st of every month via the
    <a href="https://github.com/Builder106/LinuxBenchHub/blob/main/.github/workflows/capture-benchmarks.yml" target="_blank" rel="noreferrer">capture-benchmarks</a>
    workflow. The Rails dashboard reads the same composite XML — see the
    <a href="https://github.com/Builder106/LinuxBenchHub#setup" target="_blank" rel="noreferrer">README setup section</a>
    to run it locally.
  </div>

  <%= render "shared/facet_divider" %>

  <section class="section">
    <%= render "shared/section_flag", heading: "Sample results — Ubuntu 24.04" %>
    <p style="color: var(--fg-muted); max-width: 60ch;">
      The fully parsed sample runs on 2× Intel Core i5-7360U (3 cores),
      4 GB RAM, 21 GB disk, in VMware Fusion Pro 13.6.1. Each benchmark
      ran 9 times; the dot shows the mean, the band shows ±1σ around it.
    </p>

    <div class="data-panel">
      <% @benchmarks.each do |b| %>
        <div class="data-row">
          <div class="data-label">
            <%= b.name %>
            <small><%= b.test %></small>
          </div>
          <div class="data-unit"><%= b.unit %></div>
          <div class="data-value"><%= b.mean_label %></div>
          <div class="spread" aria-hidden="true">
            <div class="spread-track"></div>
            <% lo = spread_pct(b.mean - b.stddev, b.min, b.max) %>
            <% hi = spread_pct(b.mean + b.stddev, b.min, b.max) %>
            <div class="spread-range" style="left: <%= lo %>%; width: <%= hi - lo %>%;"></div>
            <div class="spread-tick" style="left: 0%;"></div>
            <div class="spread-tick" style="left: 100%;"></div>
            <div class="spread-mean" style="left: <%= spread_pct(b.mean, b.min, b.max) %>%;"></div>
          </div>
        </div>
      <% end %>
      <div class="data-footnote">
        n = 9 runs · ±1σ band around mean · min/max as range
      </div>
    </div>
  </section>

  <%= render "shared/facet_divider" %>

  <section class="section">
    <%= render "shared/section_flag", heading: "Per-distro writeups", with_tux: true %>
    <p style="color: var(--fg-muted); max-width: 60ch;">
      Three distros, same VM specs, each capture parsed from its own
      <code>composite.xml</code> on the monthly CI run.
    </p>
    <div class="hex-cluster">
      <% @distros.each do |d| %>
        <%= link_to benchmark_path(distro: d[:slug]), class: "hex-tile" do %>
          <div class="hex-tile-inner">
            <div class="hex-tile-mark">
              <%= render "shared/distro_mark", distro: d[:slug], size: 44 %>
            </div>
            <div class="hex-tile-name"><%= d[:name] %></div>
            <div class="hex-tile-version"><%= d[:version] %></div>
            <% if d[:stat] %>
              <div class="hex-tile-stat"><%= format_stat(d[:stat][:value]) %><small><%= d[:stat][:unit] %></small></div>
              <div class="hex-tile-stat-label"><%= d[:stat][:label] %></div>
            <% else %>
              <div class="hex-tile-stat-pending">capture pending</div>
            <% end %>
            <div class="hex-tile-cta">View writeup →</div>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>

  <%= render "shared/facet_divider" %>

  <section class="section">
    <%= render "shared/section_flag", heading: "How the pieces fit" %>
    <p style="color: var(--fg-muted); max-width: 60ch;">
      The R parsers and the Rails ingester are interchangeable consumers
      of the same <code>pts/composite.xml</code> — run the static
      analysis with R alone, or use the dashboard alone, or both.
    </p>
    <%= render "pages/flowchart" %>
  </section>

  <%= render "shared/facet_divider" %>

  <section class="section">
    <%= render "shared/section_flag", heading: "Tech stack" %>
    <div style="margin-top: 20px;">
      <% @stack.each do |group| %>
        <div class="stack-group">
          <div class="stack-label"><%= group[:label] %></div>
          <div class="stack-chips">
            <% group[:chips].each do |chip| %>
              <span class="chip"><%= chip %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%= render "shared/facet_divider" %>

  <section class="section">
    <%= render "shared/section_flag", heading: "Project status" %>
    <div class="status-panel">
      <% @status_rows.each do |row| %>
        <div class="status-row">
          <span class="status-pill <%= row[:pill] %>"><%= row[:pill].upcase %></span>
          <span><%= sanitize(row[:text], tags: %w[code]) %></span>
        </div>
      <% end %>
    </div>
  </section>
</main>
