<%
  nodes = {
    vmware:    { x: 80,  y: 200, l1: "GitHub",    l2: "Actions" },
    pts:       { x: 240, y: 200, l1: "Phoronix",  l2: "Test Suite" },
    composite: { x: 420, y: 200, l1: "composite", l2: ".xml" },
    rparser:   { x: 600, y: 90,  l1: "Parse_*.R", l2: "dplyr · ggplot2" },
    writeups:  { x: 800, y: 90,  l1: ".md",       l2: "writeups" },
    rails:     { x: 600, y: 310, l1: "Rails 8",   l2: "+ Devise",    emphasis: true },
    dashboard: { x: 800, y: 310, l1: "Chartkick", l2: "+ Groupdate", emphasis: true }
  }
  r = ApplicationHelper::FLOW_HEX_R
  arrows = [
    { x1: nodes[:vmware][:x] + r,     y1: nodes[:vmware][:y],        x2: nodes[:pts][:x] - r,        y2: nodes[:pts][:y],        label: "cron" },
    { x1: nodes[:pts][:x] + r,        y1: nodes[:pts][:y],           x2: nodes[:composite][:x] - r,  y2: nodes[:composite][:y],  label: "batch" },
    { x1: nodes[:composite][:x] + 28, y1: nodes[:composite][:y] - 30, x2: nodes[:rparser][:x] - 28,  y2: nodes[:rparser][:y] + 30 },
    { x1: nodes[:composite][:x] + 28, y1: nodes[:composite][:y] + 30, x2: nodes[:rails][:x] - 28,    y2: nodes[:rails][:y] - 30 },
    { x1: nodes[:rparser][:x] + r,    y1: nodes[:rparser][:y],       x2: nodes[:writeups][:x] - r,   y2: nodes[:writeups][:y] },
    { x1: nodes[:rails][:x] + r,      y1: nodes[:rails][:y],         x2: nodes[:dashboard][:x] - r,  y2: nodes[:dashboard][:y] }
  ]
%>
<div class="flowchart">
  <svg viewBox="0 0 900 400" xmlns="http://www.w3.org/2000/svg">
    <text x="<%= nodes[:vmware][:x] %>" y="30" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--fg-dim)" letter-spacing="0.18em" font-weight="700">CAPTURE</text>
    <text x="<%= nodes[:composite][:x] %>" y="30" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--fg-dim)" letter-spacing="0.18em" font-weight="700">INGEST</text>
    <text x="<%= (nodes[:rparser][:x] + nodes[:writeups][:x]) / 2 %>" y="30" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--fg-dim)" letter-spacing="0.18em" font-weight="700">ANALYZE (R)</text>
    <text x="<%= (nodes[:rails][:x] + nodes[:dashboard][:x]) / 2 %>" y="370" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--fg-dim)" letter-spacing="0.18em" font-weight="700">DASHBOARD (RUBY)</text>

    <% arrows.each do |a| %>
      <% geo = flow_arrow_geometry(a[:x1], a[:y1], a[:x2], a[:y2]) %>
      <g>
        <line x1="<%= a[:x1] %>" y1="<%= a[:y1] %>" x2="<%= geo[:ax] %>" y2="<%= geo[:ay] %>" stroke="var(--accent)" stroke-width="1.2" opacity="0.85"/>
        <polygon points="0,0 -8,-4 -8,4" fill="var(--accent)" opacity="0.95" transform="translate(<%= geo[:ax] %>,<%= geo[:ay] %>) rotate(<%= geo[:angle] %>)"/>
        <% if a[:label] %>
          <text x="<%= (a[:x1] + a[:x2]) / 2 %>" y="<%= (a[:y1] + a[:y2]) / 2 - 6 %>" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--fg-dim)" letter-spacing="0.1em"><%= a[:label] %></text>
        <% end %>
      </g>
    <% end %>

    <% nodes.each_value do |n| %>
      <g transform="translate(<%= n[:x] %>,<%= n[:y] %>)">
        <polygon points="<%= flow_hex_points %>"
                 fill="<%= n[:emphasis] ? "var(--panel-emphasis)" : "var(--panel)" %>"
                 stroke="<%= n[:emphasis] ? "var(--accent)" : "var(--border-warm-bright)" %>"
                 stroke-width="<%= n[:emphasis] ? "1.4" : "1" %>"/>
        <text text-anchor="middle" dy="<%= n[:l2] ? "-2" : "5" %>" font-family="var(--font-mono)" font-size="11" font-weight="600" fill="var(--fg)" letter-spacing="0.02em"><%= n[:l1] %></text>
        <% if n[:l2] %>
          <text text-anchor="middle" dy="14" font-family="var(--font-mono)" font-size="10" fill="var(--fg-muted)" letter-spacing="0.04em"><%= n[:l2] %></text>
        <% end %>
      </g>
    <% end %>
  </svg>
</div>
