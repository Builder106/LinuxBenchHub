<!DOCTYPE html>
<html lang="en">
  <head>
    <script>
      (function(){try{var t=localStorage.getItem('theme');if(t==='light'||t==='dark'){document.documentElement.setAttribute('data-theme',t);}}catch(e){}})();
    </script>

    <title><%= content_for?(:title) ? content_for(:title) : "LinuxBenchHub: VM benchmarks for Linux distros" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="<%= content_for?(:meta_description) ? content_for(:meta_description) : "Compare Linux distros under identical virtual hardware. Phoronix Test Suite results for Ubuntu, Fedora, and Debian." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" type="image/svg+xml" href="<%= image_path('showcase/favicon.svg') %>">
    <link rel="apple-touch-icon" href="<%= image_path('showcase/apple-touch-icon.png') %>">

    <meta property="og:title" content="LinuxBenchHub">
    <meta property="og:description" content="VM benchmarks for Linux distros: Ubuntu, Fedora, Debian under identical virtual hardware.">
    <meta property="og:image" content="<%= image_url('showcase/social-card.png') %>">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="LinuxBenchHub">
    <meta name="twitter:description" content="VM benchmarks for Linux distros: Ubuntu, Fedora, Debian under identical virtual hardware.">
    <meta name="twitter:image" content="<%= image_url('showcase/social-card.png') %>">

    <%= stylesheet_link_tag "showcase", "data-turbo-track": "reload" %>
  </head>

  <body>
    <div class="page">
      <nav class="nav">
        <div class="nav-brand">
          <div class="nav-brand-marks">
            <%= render "showcase/hex_mark", size: 20 %>
            <%= render "showcase/tux_mark", size: 20 %>
          </div>
          <span>LinuxBenchHub</span>
        </div>
        <div class="nav-links">
          <%= link_to "Overview", showcase_path %>
          <%= link_to showcase_distro_path(distro: "ubuntu"), class: "nav-distro" do %>
            <%= render "showcase/distro_mark", distro: "ubuntu", size: 18, css_class: "nav-distro-mark" %>
            Ubuntu
          <% end %>
          <%= link_to showcase_distro_path(distro: "fedora"), class: "nav-distro" do %>
            <%= render "showcase/distro_mark", distro: "fedora", size: 18, css_class: "nav-distro-mark" %>
            Fedora
          <% end %>
          <%= link_to showcase_distro_path(distro: "debian"), class: "nav-distro" do %>
            <%= render "showcase/distro_mark", distro: "debian", size: 18, css_class: "nav-distro-mark" %>
            Debian
          <% end %>
          <a href="https://github.com/Builder106/LinuxBenchHub" target="_blank" rel="noreferrer" class="nav-github" aria-label="LinuxBenchHub on GitHub">
            <%= render "showcase/github_mark", size: 16, css_class: "nav-github-mark" %>
            GitHub
          </a>
          <a href="<%= root_path %>" class="nav-app-link">Dashboard →</a>
          <button class="theme-toggle" id="showcase-theme-toggle" type="button" aria-label="Toggle theme">
            <span class="theme-toggle-icon theme-toggle-icon-sun">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="12" cy="12" r="4" fill="currentColor" />
                <g stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                  <line x1="12" y1="2" x2="12" y2="5" /><line x1="12" y1="19" x2="12" y2="22" />
                  <line x1="2" y1="12" x2="5" y2="12" /><line x1="19" y1="12" x2="22" y2="12" />
                  <line x1="4.93" y1="4.93" x2="7.05" y2="7.05" /><line x1="16.95" y1="16.95" x2="19.07" y2="19.07" />
                  <line x1="4.93" y1="19.07" x2="7.05" y2="16.95" /><line x1="16.95" y1="7.05" x2="19.07" y2="4.93" />
                </g>
              </svg>
            </span>
            <span class="theme-toggle-icon theme-toggle-icon-moon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="currentColor" />
              </svg>
            </span>
          </button>
        </div>
      </nav>

      <%= yield %>

      <footer class="footer">
        <div class="footer-brand">
          <%= render "showcase/hex_mark", size: 14 %>
          <%= render "showcase/tux_mark", size: 14 %>
          <span>LINUXBENCHHUB &middot; MIT</span>
        </div>
        <div>
          <a href="https://github.com/Builder106" target="_blank" rel="noreferrer">@BUILDER106</a>
        </div>
      </footer>
    </div>

    <script>
      (function () {
        var btn = document.getElementById('showcase-theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var current = document.documentElement.getAttribute('data-theme');
          if (!current) {
            var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
            current = prefersLight ? 'light' : 'dark';
          }
          var next = current === 'light' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
