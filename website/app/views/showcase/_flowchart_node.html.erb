<%
l2 = local_assigns[:l2]
emphasis = local_assigns[:emphasis]
%>
<g transform="translate(<%= x %>,<%= y %>)">
  <polygon points="<%= showcase_hex_points %>" fill="<%= emphasis ? 'var(--panel-emphasis)' : 'var(--panel)' %>" stroke="<%= emphasis ? 'var(--accent)' : 'var(--border-warm-bright)' %>" stroke-width="<%= emphasis ? '1.4' : '1' %>" />
  <text text-anchor="middle" dy="<%= l2 ? '-2' : '5' %>" font-family="var(--font-mono)" font-size="11" font-weight="600" fill="var(--fg)" letter-spacing="0.02em"><%= l1 %></text>
  <% if l2 %>
    <text text-anchor="middle" dy="14" font-family="var(--font-mono)" font-size="10" fill="var(--fg-muted)" letter-spacing="0.04em"><%= l2 %></text>
  <% end %>
</g>
