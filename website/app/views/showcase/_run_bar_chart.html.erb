<% if runs.empty? %>
  <div class="run-chart-empty">No per-run data parsed for this test.</div>
<% else %>
  <%
  values = runs.map { |r| r[:value] }
  max = [values.max, mean].max
  scale_max = max * 1.08

  width = 640
  height = 220
  pad = { top: 16, right: 16, bottom: 28, left: 56 }
  chart_w = width - pad[:left] - pad[:right]
  chart_h = height - pad[:top] - pad[:bottom]

  slot = chart_w.to_f / runs.length
  bar_w = slot * 0.66

  y_for = ->(v) { pad[:top] + chart_h - (v / scale_max) * chart_h }

  grid_ticks = 4
  tick_step = scale_max / grid_ticks
  %>
  <figure class="run-chart">
    <svg viewBox="0 0 <%= width %> <%= height %>" role="img" aria-label="Per-run <%= unit %> values">
      <% (0..grid_ticks).each do |i| %>
        <% v = tick_step * i; y = y_for.call(v) %>
        <g>
          <line x1="<%= pad[:left] %>" x2="<%= width - pad[:right] %>" y1="<%= y %>" y2="<%= y %>" stroke="var(--border-warm)" stroke-width="0.6" opacity="<%= i == 0 ? 0.9 : 0.45 %>" />
          <text x="<%= pad[:left] - 8 %>" y="<%= y + 3 %>" text-anchor="end" font-family="var(--font-mono)" font-size="10" fill="var(--fg-dim)"><%= showcase_format_tick(v) %></text>
        </g>
      <% end %>

      <% runs.each_with_index do |r, i| %>
        <% x = pad[:left] + slot * i + (slot - bar_w) / 2; y = y_for.call(r[:value]); h = pad[:top] + chart_h - y %>
        <g>
          <rect x="<%= x %>" y="<%= y %>" width="<%= bar_w %>" height="<%= h %>" fill="var(--accent)" opacity="0.92">
            <title>Run <%= r[:run] %>: <%= r[:value] %> <%= unit %></title>
          </rect>
          <text x="<%= x + bar_w / 2 %>" y="<%= pad[:top] + chart_h + 16 %>" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--fg-dim)"><%= r[:run] %></text>
        </g>
      <% end %>

      <% if mean > 0 %>
        <g>
          <line x1="<%= pad[:left] %>" x2="<%= width - pad[:right] %>" y1="<%= y_for.call(mean) %>" y2="<%= y_for.call(mean) %>" stroke="var(--accent-bright)" stroke-width="1.2" stroke-dasharray="4 4" />
          <text x="<%= width - pad[:right] %>" y="<%= y_for.call(mean) - 5 %>" text-anchor="end" font-family="var(--font-mono)" font-size="10" fill="var(--accent-bright)" font-weight="600" letter-spacing="0.06em">MEAN <%= showcase_format_tick(mean) %></text>
        </g>
      <% end %>
    </svg>
    <figcaption>run <%= runs.first[:run] %>&ndash;<%= runs.last[:run] %> &middot; bars in <%= unit %> &middot; dashed line is mean</figcaption>
  </figure>
<% end %>
