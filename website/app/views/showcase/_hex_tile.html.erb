<a class="hex-tile" href="<%= showcase_distro_path(distro: slug) %>">
  <div class="hex-tile-inner">
    <div class="hex-tile-mark">
      <%= render "showcase/distro_mark", distro: slug, size: 44 %>
    </div>
    <div class="hex-tile-name"><%= name %></div>
    <div class="hex-tile-version"><%= version %></div>
    <% if stat %>
      <div class="hex-tile-stat"><%= stat[:value] %><small><%= stat[:unit] %></small></div>
      <div class="hex-tile-stat-label"><%= stat[:label] %></div>
    <% else %>
      <div class="hex-tile-stat-pending">capture pending</div>
    <% end %>
    <div class="hex-tile-cta">View writeup →</div>
  </div>
</a>
