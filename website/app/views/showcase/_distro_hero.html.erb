<header class="distro-hero">
  <div class="distro-hero-mark">
    <%= render "showcase/distro_mark", distro: distro, size: 84 %>
  </div>
  <div class="distro-hero-body">
    <div class="distro-hero-eyebrow">PHORONIX TEST SUITE <%= pts %></div>
    <h1 class="distro-hero-name">
      <%= name %>
      <span class="distro-hero-version"><%= version %></span>
    </h1>
    <p class="distro-hero-intro"><%= intro %></p>
  </div>
</header>
