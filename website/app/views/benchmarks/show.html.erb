<% content_for :title, "#{@meta[:name]} #{@meta[:version]} benchmarks — LinuxBenchHub" %>
<% content_for :description, "Phoronix Test Suite #{@meta[:pts]} results for #{@meta[:name]} #{@meta[:version]} captured on VMware Fusion Pro 13.6.1." %>

<main>
  <a href="/" class="back-link">← OVERVIEW</a>

  <header class="distro-hero">
    <div class="distro-hero-mark">
      <%= render "shared/distro_mark", distro: @distro.slug, size: 84 %>
    </div>
    <div class="distro-hero-body">
      <div class="distro-hero-eyebrow">PHORONIX TEST SUITE <%= @meta[:pts] %></div>
      <h1 class="distro-hero-name">
        <%= @meta[:name] %>
        <span class="distro-hero-version"><%= @meta[:version] %></span>
      </h1>
      <p class="distro-hero-intro"><%= @distro.intro %></p>
    </div>
  </header>

  <nav class="section-nav" aria-label="Benchmarks">
    <a href="#system-information">System</a>
    <% @distro.sections.each do |section| %>
      <a href="#<%= section.anchor %>"><%= section.name.sub(/\s+Benchmark\z/i, "") %></a>
    <% end %>
  </nav>

  <%= render "shared/facet_divider" %>

  <section class="system-card" id="system-information">
    <h2 class="system-card-heading">System</h2>
    <div class="system-card-cols">
      <% { "Hardware" => @distro.hardware, "Software" => @distro.software }.each do |label, pairs| %>
        <div class="system-card-col">
          <div class="system-card-col-label"><%= label %></div>
          <dl class="system-card-list">
            <% pairs.each do |pair| %>
              <div class="system-card-row">
                <dt><%= pair.key %></dt>
                <dd><%= pair.value %></dd>
              </div>
            <% end %>
          </dl>
        </div>
      <% end %>
    </div>
  </section>

  <% @distro.sections.each do |section| %>
    <section class="bench-section" id="<%= section.anchor %>">
      <%= render "shared/facet_divider" %>
      <h2 class="bench-section-heading"><%= section.name %></h2>
      <% section.tests.each do |test| %>
        <%= render "benchmarks/benchmark_card", test: test %>
      <% end %>
    </section>
  <% end %>
</main>
