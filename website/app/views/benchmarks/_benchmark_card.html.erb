<article class="bench-card">
  <header class="bench-card-head">
    <div class="bench-card-headline">
      <div class="bench-card-name">
        <%= test.title %>
        <% if test.description.present? %>
          <span class="bench-card-desc"> · <%= test.description %></span>
        <% end %>
      </div>
      <code class="bench-card-ident"><%= test.identifier %></code>
    </div>
    <% if test.app_version.present? || test.args.present? %>
      <dl class="bench-card-meta">
        <% if test.app_version.present? %>
          <div>
            <dt>App</dt>
            <dd><%= test.app_version %></dd>
          </div>
        <% end %>
        <% if test.args.present? %>
          <div>
            <dt>Args</dt>
            <dd><code><%= test.args %></code></dd>
          </div>
        <% end %>
      </dl>
    <% end %>
  </header>

  <div class="bench-card-stats">
    <div class="stat-cell stat-cell-emphasis">
      <div class="stat-cell-label">Mean</div>
      <div class="stat-cell-value"><%= format_stat(test.mean) %><small><%= test.unit %></small></div>
    </div>
    <div class="stat-cell">
      <div class="stat-cell-label">Median</div>
      <div class="stat-cell-value"><%= format_stat(test.median) %><small><%= test.unit %></small></div>
    </div>
    <div class="stat-cell">
      <div class="stat-cell-label">Std Dev</div>
      <div class="stat-cell-value"><%= format_stat(test.stddev) %><small><%= test.unit %></small></div>
    </div>
    <div class="stat-cell">
      <div class="stat-cell-label">Runs</div>
      <div class="stat-cell-value"><%= test.runs.length %><small>n</small></div>
    </div>
  </div>

  <%= render "benchmarks/run_bar_chart", runs: test.runs, unit: test.unit, mean: test.mean %>
</article>
